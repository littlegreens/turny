# Copia in .env e compila (il file .env non va committato).
NODE_ENV=production

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public

NEXTAUTH_URL=https://turny.clipy.it
NEXTAUTH_SECRET=

SUPER_ADMIN_EMAILS=
RESEND_API_KEY=
EMAIL_FROM="Turny <noreply@turny.clipy.it>"

# Generazione turni (FastAPI turny-scheduler). In produzione sullo stesso server:
# SCHEDULER_SERVICE_URL=http://127.0.0.1:8000
SCHEDULER_SERVICE_URL=http://127.0.0.1:8000
